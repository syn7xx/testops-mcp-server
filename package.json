{
  "name": "@syn7xx/testops-mcp-server",
  "version": "0.1.5",
  "description": "TestOps MCP Server - Model Context Protocol server for test operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "bin": {
    "testops-mcp-server": "dist/index.js"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testops",
    "automation"
  ],
  "author": "syn7xx <ethorz.ru@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/syn7xx/testops-mcp-server.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^17.4.0",
    "prettier": "^3.2.0",
    "release-it": "^19.2.4",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "conventional-changelog-conventionalcommits": "8.0.0"
  }
}
